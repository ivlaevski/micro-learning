{
  "name": "micro-learning",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0 --strictPort",
    "build": "vite build && node scripts/bump-build.mjs",
    "preview": "vite preview --host 0.0.0.0 --strictPort",
    "qr": "evenhub qr --port 5174 --path /",
    "init:evenhub": "evenhub init --output app.json",
    "pack": "npm run build && evenhub pack app.json ./dist --output micro-learning.ehpk",
    "pack:check": "evenhub pack app.json ./dist --check"
  },
  "dependencies": {
    "@elevenlabs/elevenlabs-js": "^2.41.1",
    "@evenrealities/even_hub_sdk": "^0.0.9",
    "@evenrealities/evenhub-cli": "^0.1.11"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "vite": "^6.4.1"
  }
}
